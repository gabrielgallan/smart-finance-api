{
  "compilerOptions": {
    // "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@/*": ["./src/*"],
    },

    "module": "esnext",            // <- Usa import/export moderno
    "target": "es2020",            // OK para Node moderno
    "moduleResolution": "node",

    "strict": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "skipLibCheck": true,

    "noEmit": true,
    "allowImportingTsExtensions": true,

    "types": [
      "node", "vitest/globals"
    ]
  },
  "include": [
    "./"
  ],
  "exclude": ["dist", "node_modules"]
}